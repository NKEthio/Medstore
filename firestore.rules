rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
             && request.auth.token.admin == true;
    }

    // Anyone can read the product catalog; users with the admin custom claim
    // can create, edit, and delete products from the admin route.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // A signed-in user can create orders for themselves and read
    // only their own orders. Orders can't be edited or deleted
    // from the client once placed.
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
